{
  "name": "monkey-d-loopy",
  "private": true,
  "version": "0.6.0",
  "description": "A factory for runnable, crash-resumable agent loops. Define a loop once; compile it to multiple runnable targets with termination and cost guarantees baked in.",
  "author": "MaTriXy <elkriefy@gmail.com>",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/MaTriXy/Monkey.D.Loopy.git" },
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "docs:dev": "pnpm agent-docs:generate && vitepress dev docs",
    "docs:build": "pnpm agent-docs:check && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "security:audit": "pnpm audit --audit-level=low",
    "typecheck": "pnpm recipes:check && pnpm -r typecheck",
    "test": "pnpm -r test",
    "eval": "pnpm --filter @loopyc/evals eval",
    "eval:skill": "pnpm --filter @loopyc/evals eval:skill",
    "loopc": "pnpm --filter @loopyc/cli loopc",
    "onboarding:smoke": "node scripts/pack-smoke.mjs",
    "release:check": "node scripts/check-release-parity.mjs",
    "release:pack-smoke": "node scripts/pack-smoke.mjs",
    "agent-docs:generate": "node scripts/generate-agent-docs.mjs",
    "agent-docs:check": "node scripts/generate-agent-docs.mjs --check",
    "recipes:generate": "node scripts/generate-recipe-catalog.mjs",
    "recipes:check": "node scripts/generate-recipe-catalog.mjs --check"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"],
    "overrides": {
      "bundle-require>esbuild": "^0.28.1",
      "tsup>esbuild": "^0.28.1",
      "vitepress>vite": "^6.4.3"
    }
  }
}
