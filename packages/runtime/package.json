{
  "name": "@loopyc/runtime",
  "version": "0.7.0",
  "description": "The durable execution engine for Monkey D Loopy standalone loop artifacts: event-sourced journal, deterministic replay, idempotent effects, hard caps, durable sleep + breakpoints.",
  "author": "MaTriXy <elkriefy@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaTriXy/Monkey.D.Loopy.git",
    "directory": "packages/runtime"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {},
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "agent",
    "agent-loop",
    "llm",
    "loopspec",
    "durable-execution",
    "bounded",
    "crash-resumable",
    "automation"
  ],
  "homepage": "https://github.com/MaTriXy/Monkey.D.Loopy#readme",
  "bugs": "https://github.com/MaTriXy/Monkey.D.Loopy/issues"
}
