{
  "name": "@loopyc/operator",
  "version": "0.6.1",
  "description": "Local-first operator, journal read model, scheduler, and control center for Monkey D Loopy.",
  "author": "MaTriXy <elkriefy@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaTriXy/Monkey.D.Loopy.git",
    "directory": "packages/operator"
  },
  "type": "module",
  "bin": { "loopyd": "./dist/cli.js" },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "files": ["dist", "assets"],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
    "access": "public",
    "bin": { "loopyd": "./dist/cli.js" }
  },
  "scripts": {
    "build": "pnpm --filter @loopyc/control-center build && tsup",
    "prepack": "pnpm --filter @loopyc/control-center build && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loopyc/core": "workspace:*",
    "@loopyc/runtime": "workspace:*",
    "@loopyc/verify": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "engines": { "node": ">=22" },
  "keywords": ["agent", "operator", "scheduler", "observability", "durable-execution"],
  "homepage": "https://github.com/MaTriXy/Monkey.D.Loopy#readme",
  "bugs": "https://github.com/MaTriXy/Monkey.D.Loopy/issues"
}
