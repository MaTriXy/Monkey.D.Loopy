exports[`babysitter adapter > matches the golden snapshot 1`] = `
"// Generated by Monkey D Loopy (@loopy/core). Target: babysitter durable process (@a5c-ai/babysitter-sdk).
// Do not hand-edit — edit the LoopSpec and recompile.
// loop: deploy-watch  pattern: poll-until  exit: \${state.status == 'green'} (state-predicate)

import { defineTask } from "@a5c-ai/babysitter-sdk";

function __in(l, r) {
  if (Array.isArray(r)) return r.includes(l);
  if (typeof r === "string") return r.includes(String(l));
  if (r && typeof r === "object") return l != null && String(l) in r;
  return false;
}
function __jsonpath(obj, path) {
  if (obj == null) return undefined;
  let cur = obj;
  for (const seg of String(path).replace(/^\\$\\.?/, "").split(".")) {
    if (!seg) continue;
    const m = /^([^\\[]*)(?:\\[(\\d+)\\])?$/.exec(seg);
    if (m && m[1]) cur = cur?.[m[1]];
    if (m && m[2] != null) cur = cur?.[Number(m[2])];
    if (cur == null) return undefined;
  }
  return cur;
}
function __sq(s) {
  // POSIX single-quote: wrap in quotes and replace each ' with '\\'' (built via char
  // codes so no quote/backslash literals appear here). Neutralizes $, backtick, \\\\, etc.
  var q = String.fromCharCode(39), bs = String.fromCharCode(92);
  return q + String(s).split(q).join(q + bs + q + q) + q;
}
function __curl(req) {
  const flags = ["-s", "-X", req.method];
  for (const [k, v] of Object.entries(req.headers || {})) flags.push("-H", __sq(k + ": " + v));
  if (req.body !== undefined) flags.push("--data", __sq(typeof req.body === "string" ? req.body : JSON.stringify(req.body)));
  // envelope: append a -w sentinel after the body so __httpEnv can recover the status/headers
  // (the body alone carries no status). %{header_json} needs curl >= 7.83 (else headers => {}).
  if (req.envelope) flags.push("-w", __sq("__LOOPY_HTTP__%{http_code}__LOOPY_SEP__%{header_json}"));
  flags.push(__sq(req.url));
  return "curl " + flags.join(" ");
}
function __tryJson(t) { try { return JSON.parse(t); } catch { return t; } }
function __httpEnv(raw) {
  // Reconstruct { status, ok, headers, body } from a curl whose -w writeout appended
  // "__LOOPY_HTTP__<status>__LOOPY_SEP__<header_json>" after the body. JS does the parsing,
  // so a non-JSON body is handled safely (the shell never has to assemble JSON itself).
  const s = typeof raw === "string" ? raw : raw == null ? "" : JSON.stringify(raw);
  // Structure-aware split: match the sentinel + status digits + SEP and take the LAST well-formed
  // occurrence. The real writeout is appended at the very end, so a body/header value that merely
  // contains the literal sentinel can't hijack the split (a bare lastIndexOf could).
  const re = /__LOOPY_HTTP__(\\d+)__LOOPY_SEP__/g;
  let m, last;
  while ((m = re.exec(s)) !== null) last = m;
  if (!last) return { status: 0, ok: false, headers: {}, body: __tryJson(s) };
  const body = __tryJson(s.slice(0, last.index));
  const status = Number(last[1]) || 0;
  let headers = {};
  try {
    const parsed = JSON.parse(s.slice(last.index + last[0].length)) || {};
    // Normalize curl's header_json (original-case keys, ARRAY values) to execHttp's shape so the
    // { status, ok, headers, body } envelope is identical across targets: lowercase keys, joined
    // string values — so save: { ct: "$.headers.content-type" } reads a string here, as it does
    // under the standalone/interpreter execHttp.
    headers = Object.fromEntries(Object.entries(parsed).map(([k, v]) => [k.toLowerCase(), Array.isArray(v) ? v.join(", ") : String(v)]));
  } catch {}
  return { status, ok: status >= 200 && status < 300, headers, body };
}

const __shellTask = defineTask("loopy-shell", (args) => ({
  kind: "shell",
  title: args.title,
  shell: { command: args.command },
}));
const __agentTask = defineTask("loopy-agent", (args) => ({
  kind: "agent",
  title: args.title,
  agent: { name: args.name, prompt: args.prompt },
  execution: { harness: args.harness },
}));

export const spec = {
  "id": "deploy-watch",
  "meta": {
    "name": "deploy-watch",
    "version": "0.1.0",
    "description": "Poll a deploy status; if red, let an agent push a fix; exit when green."
  },
  "pattern": "poll-until",
  "target": "babysitter",
  "caps": {
    "max_iterations": 288,
    "no_progress": {
      "fingerprint": "\${state.status}",
      "max_repeats": 12
    },
    "budget": {
      "tokens": 200000,
      "usd": 5,
      "wallclock": "24h"
    },
    "on_cap_exceeded": "breakpoint"
  },
  "schedule": {
    "mode": "forever"
  }
};

export async function process(inputs, ctx) {
  const meta = {"name":"deploy-watch","version":"0.1.0","description":"Poll a deploy status; if red, let an agent push a fix; exit when green."};
  const env = (ctx && ctx.env) || {}; // note: babysitter ProcessContext has no env; refs resolve to {}
  let state = {"status":"pending","attempt":0};
  let iteration = 0;
  let __lastFp;
  let __fpRepeats = 0;
  const MAX_ITERATIONS = 288;
  while (!((state?.status === "green"))) {
    if (iteration >= MAX_ITERATIONS) {
      const __r = await ctx.breakpoint({ label: "cap", question: "cap exceeded: max_iterations — approve continuation?" });
      if (!__r.approved) break;
      iteration = 0;
    }
    // step: check
    {
      const __res = await ctx.task(__shellTask, { title: "check", command: __curl({ method: "GET", url: \`\${inputs?.status_url}\` }) });
      state["status"] = __jsonpath(__res, "$.state");
    }
    // step: triage
    if ((state?.status === "red")) {
      await ctx.task(__agentTask, { title: "triage", name: "triage", prompt: \`Deploy failed (attempt \${state?.attempt}). Diagnose and push a minimal fix.\`, harness: "cli" });
      state["attempt"] = state["attempt"] + 1;
    }
    // step: wait
    if ((state?.status === "pending")) {
      await ctx.sleepUntil(ctx.now().getTime() + 300000);
    }
    const __fp = String(state?.status);
    if (__fp === __lastFp) {
      if (++__fpRepeats >= 12) {
        const __r = await ctx.breakpoint({ label: "cap", question: "cap exceeded: no_progress — approve continuation?" });
        if (!__r.approved) break;
        __fpRepeats = 0; __lastFp = undefined;
      }
    } else { __fpRepeats = 0; __lastFp = __fp; }
    iteration++;
  }
  await ctx.task(__shellTask, { title: "on_exit", command: \`echo deploy \${state?.status}\` });
  return state;
}
"
`;

exports[`standalone adapter > matches the golden snapshot 1`] = `
"#!/usr/bin/env node
// Generated by Monkey D Loopy (@loopy/core). Do not edit by hand — edit the LoopSpec and recompile.
// loop: deploy-watch  target: standalone  pattern: poll-until

import { createRuntime, __in } from "@loopy/runtime";
import { pathToFileURL } from "node:url";
import { realpathSync } from "node:fs";

const spec = {
  "id": "deploy-watch",
  "meta": {
    "name": "deploy-watch",
    "version": "0.1.0",
    "description": "Poll a deploy status; if red, let an agent push a fix; exit when green."
  },
  "pattern": "poll-until",
  "target": "standalone",
  "signal": "state-predicate",
  "caps": {
    "max_iterations": 288,
    "no_progress": {
      "fingerprint": "\${state.status}",
      "max_repeats": 12
    },
    "budget": {
      "tokens": 200000,
      "usd": 5,
      "wallclock": "24h"
    },
    "on_cap_exceeded": "breakpoint"
  },
  "schedule": {
    "mode": "forever"
  },
  "observe": {
    "trace": "journal"
  }
};

export function initialState() {
  return {"status":"pending","attempt":0};
}

export function terminate(ctx) {
  const { state, inputs, env, iteration, meta } = ctx;
  return ((state?.status === "green"));
}

export function fingerprint(ctx) {
  const { state, inputs, env, iteration, meta } = ctx;
  return String(state?.status);
}

export async function iterate(ctx) {
  const { state, inputs, env, iteration, meta } = ctx;
  // step: check
  {
    const __res = await ctx.http({ method: "GET", url: \`\${inputs?.status_url}\` });
    state["status"] = ctx.jsonpath(__res, "$.state");
  }
  // step: triage
  if ((state?.status === "red")) {
    await ctx.agent({ harness: "cli", prompt: \`Deploy failed (attempt \${state?.attempt}). Diagnose and push a minimal fix.\` });
    state["attempt"] = state["attempt"] + 1;
  }
  // step: wait
  if ((state?.status === "pending")) {
    await ctx.sleep("5m");
  }
}

export async function onExit(ctx) {
  const { state, inputs, env, iteration, meta } = ctx;
  await ctx.shell(\`echo deploy \${state?.status}\`);
}

export const runtime = createRuntime({
  spec,
  initialState,
  iterate,
  terminate,
  fingerprint,
  onExit,
});

// Self-references __in for the \`in\` operator in lowered expressions.
void __in;

// Run main() when invoked directly — symlink-robust (works through a bin symlink).
const __entry = process.argv[1] ? pathToFileURL(realpathSync(process.argv[1])).href : "";
if (import.meta.url === __entry) {
  await runtime.main(process.argv.slice(2));
}
"
`;
