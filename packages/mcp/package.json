{
  "name": "@loopyc/mcp",
  "version": "0.5.0",
  "description": "loopc-mcp — Model Context Protocol server exposing the Monkey D Loopy factory to agents (schema, scaffold, validate, verify, compile, run, inspect).",
  "author": "MaTriXy <elkriefy@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaTriXy/Monkey.D.Loopy.git",
    "directory": "packages/mcp"
  },
  "type": "module",
  "bin": {
    "loopc-mcp": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "bin": {
      "loopc-mcp": "./dist/index.js"
    },
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "loopc-mcp": "tsx src/index.ts"
  },
  "dependencies": {
    "@loopyc/core": "workspace:*",
    "@loopyc/infer": "workspace:*",
    "@loopyc/runtime": "workspace:*",
    "@loopyc/verify": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "agent",
    "agent-loop",
    "llm",
    "loopspec",
    "durable-execution",
    "bounded",
    "crash-resumable",
    "automation"
  ],
  "homepage": "https://github.com/MaTriXy/Monkey.D.Loopy#readme",
  "bugs": "https://github.com/MaTriXy/Monkey.D.Loopy/issues"
}
